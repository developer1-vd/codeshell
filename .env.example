# Configuration Example
# Copy this to .env and modify as needed

# Ollama server address (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Ollama model to use (default: qwen:latest)
OLLAMA_MODEL=qwen:latest

# Response timeout in seconds (default: 120)
RESPONSE_TIMEOUT=120

# Command execution timeout in seconds (default: 30)
COMMAND_TIMEOUT=30
